import os

import resend

resend.api_key = os.environ.get("RESEND_API_KEY", "")


def send_email(
    to: str | list[str],
    subject: str,
    html: str,
    from_address: str = "noreply@example.com",
) -> dict:
    params: resend.Emails.SendParams = {
        "from": from_address,
        "to": [to] if isinstance(to, str) else to,
        "subject": subject,
        "html": html,
    }
    return resend.Emails.send(params)
