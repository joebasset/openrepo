[project]
name = "{{ .ProjectSlug }}"
version = "0.1.0"
description = "FastAPI service scaffolded by openrepo"
requires-python = ">=3.12"
dependencies = [
  "fastapi>=0.115.0",
  "uvicorn[standard]>=0.34.0",
  "sqlalchemy>=2.0.0",
]

[dependency-groups]
dev = [
  "pytest>=8.0.0",
  "httpx>=0.27.0",
  "ruff>=0.11.0",
]

[tool.pytest.ini_options]
pythonpath = ["."]
